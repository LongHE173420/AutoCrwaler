
KONG_URL=https://social.eric.pro.vn

INTERVAL_MS=60000
RUN_ONCE=false

AUTO_FETCH_OTP=true
AUTO_RESEND=true

OTP_TIMEOUT_MS=30000
OTP_POLL_MS=300
OTP_VERIFY_RETRY=5

VERIFY_WINDOW_MS=10000
RESEND_WINDOW_MS=10000
MAX_RESEND=2

OTP_DEBUG_PATH_REDIS=/auth/debug/redis-otp

ACCESS_TTL_MS=60000
REFRESH_TTL_MS=600000

LOG_LEVEL=debug
LOG_VERBOSE=false
LOG_HTTP=false
LOG_PASSWORD_PLAINTEXT=false
LOG_OTP_PLAINTEXT=false
LOG_TOKEN_PLAINTEXT=false
LOG_DIR=data/logs
LOG_RETENTION_DAYS=7

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cấu hình crawler TikTok
CRAWL_TIKTOK_ENABLED=true
CRAWL_INTERVAL_MS=1800000
CRAWL_LIMIT=20
VIDEO_DOWNLOAD_DIR=d:\React_Native\Demo\TikTokCrawler\data\videos\raw
MAX_POSTS_PER_VIDEO=2

TIKTOK_SEED_URLS=https://www.tiktok.com/@vtv24news,https://www.tiktok.com/@theanh28entertainment,https://www.tiktok.com/@beatvn,https://www.tiktok.com/@vtvcab.tintuc,https://www.tiktok.com/@tiin.vn,https://www.tiktok.com/@dantri.com.vn
